# Two Birds Talking -- API Keys
# Copy this file to .env and fill in your keys.
# This file is in .gitignore and should never be committed.

# Agent A API key
AGENT_A_API_KEY=your-api-key-here

# Agent B API key
AGENT_B_API_KEY=your-api-key-here

# Telegram notifications (if NOTIFY_METHOD=telegram in config.sh)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord notifications (if NOTIFY_METHOD=discord in config.sh)
DISCORD_WEBHOOK_URL=
